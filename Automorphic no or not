#include<stdio.h>
int main(){
    int num, square, temp;
    scanf("%d", &num);
    temp=num;
    while(temp>0)
    {
        if(temp%10!=square%10){
            printf("Not automorphic");
            return 0;
        }
        temp=temp/10;
        square=square/10;
    }
    printf("Automorphic");
    return 0;
}
