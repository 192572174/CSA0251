#include <stdio.h>
int main() {
    int arr[] = {1, 5, 3, 4, 2}, diff = 2, n = 5, count = 0;
    for(int i = 0; i < n; i++) {
        for(int j = i + 1; j < n; j++) {
            if(arr[i] - arr[j] == diff || arr[j] - arr[i] == diff) {
                printf("(%d, %d) ", arr[i], arr[j]);
                count++;
            }
        }
    }
    printf("\nTotal Pairs: %d\n", count);
    return 0;
}
