#include <stdio.h>
int main() {
    int arr[] = {2, 2, 1, 5, 1, 3, 3};
    int n = 7, visited = -1;
    int freq[7];
    for(int i = 0; i < n; i++) {
        int count = 1;
        for(int j = i + 1; j < n; j++) {
            if(arr[i] == arr[j]) {
                count++;
                freq[j] = visited;
            }
        }
        if(freq[i] != visited) freq[i] = count;
    }

    for(int i = 0; i < n; i++) {
        if(freq[i] != visited)
            printf("%d: %d times, ", arr[i], freq[i]);
    }
    return 0;
}
