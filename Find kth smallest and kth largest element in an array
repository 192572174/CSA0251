#include <stdio.h>
void sort(int arr[], int n) {
    int temp;
    for(int i = 0; i < n; i++)
        for(int j = i+1; j < n; j++)
            if(arr[i] > arr[j]) { temp = arr[i]; arr[i] = arr[j]; arr[j] = temp; }
}
int main() {
    int arr[] = {7, 10, 4, 3, 20, 15}, n = 6, k = 3;
    sort(arr, n);
    printf("%d-th Smallest: %d\n", k, arr[k-1]);
    printf("%d-th Largest: %d\n", k, arr[n-k]);
    return 0;
}
