#include <stdio.h>
int main() {
    int arr[] = {3, 3, 4, 2, 3, 3, 5};
    int n = 7, count = 0, element;
    for(int i = 0; i < n; i++) {
        if(count == 0) { element = arr[i]; count = 1; }
        else if(arr[i] == element) count++;
        else count--;
    }
    printf("Majority element: %d\n", element);
    return 0;
}
