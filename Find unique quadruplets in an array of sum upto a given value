#include <stdio.h>
void findQuadruplets(int arr[], int n, int target) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp; } } }
    for (int i = 0; i < n - 3; i++) {
        if (i > 0 && arr[i] == arr[i - 1]) continue;
        for (int j = i + 1; j < n - 2; j++) {
            if (j > i + 1 && arr[j] == arr[j - 1]) continue;
            int left = j + 1;
            int right = n - 1;
            while (left < right) {
                int sum = arr[i] + arr[j] + arr[left] + arr[right];
                if (sum == target) {
                    printf("[%d, %d, %d, %d]\n", arr[i], arr[j], arr[left], arr[right]);
                    while (left < right && arr[left] == arr[left + 1]) left++;
                    while (left < right && arr[right] == arr[right - 1]) right--;
                    left++;
                    right--; } 
                else if (sum < target) left++;
                else right--; }} }}
int main() {
    int arr[] = {1, 0, -1, 0, -2, 2};
    int n = 6;
    int target = 0;
    findQuadruplets(arr, n, target);
    return 0; }
