#include<stdio.h>
void main(){
    int num, temp, digit, sum;
    scanf("%d", &num);
    temp=num;
    while(temp!=1 && temp!=4 {
        sum=0;
        digit=temp%10;
        sum=sum+digit;
        temp=temp/10;
    }
    temp=sum;
    if(temp==1)
        printf("%d is a happy no", num);
    else
        printf("%d is not a happy no", num);
}
